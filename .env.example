# 複製此檔為 .env 並填入實際值
# cp .env.example .env

# ── Database ────────────────────────────────────────────────────
# 本機 Docker：DB_HOST=db（docker-compose 內部服務名稱）
# 本機直接跑：DB_HOST=localhost
# Cloud Run：使用 Supabase，填入 Supabase pooler 主機
#   例如：aws-0-ap-southeast-1.pooler.supabase.com
DB_HOST=db
DB_NAME=sensei_db
DB_USER=postgres
DB_PASSWORD=2rligaoiChen
DB_PORT=5432

# ── Gemini AI ───────────────────────────────────────────────────
# 從 Google AI Studio 取得：https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── 網路 DNS 修正（Docker 內無法解析 TDCC 時使用）──────────────
TDCC_IP=117.56.213.165
