# 複製此檔為 .env 並填入實際值
# cp .env.example .env

# ── Database ────────────────────────────────────
# Mac 本機直接跑：DB_HOST=localhost
# Docker 環境：   DB_HOST=db
DB_HOST=localhost
DB_NAME=sensei_db
DB_USER=postgres
DB_PASSWORD=
DB_PORT=5432

# ── AI ──────────────────────────────────────────
AI_PROVIDER=gemini
GEMINI_API_KEY=

# ── 網路 DNS 修正（Docker 內無法解析時使用）────────
# 若 data.tdcc.com.tw 無法連線，可在此填入目前 IP
TDCC_IP=117.56.213.165
